# Local demo setup:
# 1. Copy this file to .env
# 2. Fill in VITE_KIMI_API_KEY
# 3. Restart `npm run dev` after edits

VITE_KIMI_API_KEY=

# For local demos, /kimi-api uses the Vite dev proxy to avoid browser CORS issues.
# On Vercel, leave VITE_KIMI_BASE_URL unset or set it to /api/kimi.
VITE_KIMI_BASE_URL=/kimi-api
VITE_KIMI_MODEL=kimi-k2.6

# Vercel production setup:
# Add this in Vercel Project Settings > Environment Variables.
# Do not prefix this with VITE_ in production.
KIMI_API_KEY=

# Optional. If omitted, the Hall of Shame uses in-memory demo entries.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
